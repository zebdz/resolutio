{
  "name": "resolutio",
  "version": "1.3.10",
  "private": true,
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "next dev -p 8080",
    "build": "prisma generate && next build",
    "start": "./start-production.sh",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lf": "yarn run lint:fix && yarn run format",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:external-board-member": "npx tsx prisma/seed-external-board-member.ts",
    "db:status": "npx prisma migrate status",
    "db:migrate": "npx prisma migrate deploy",
    "db:clear": "npx tsx prisma/db-clear.ts",
    "db:superadmin:add": "npx tsx prisma/superadmin-add.ts",
    "db:superadmin:remove": "npx tsx prisma/superadmin-remove.ts",
    "db:user-confirm": "npx tsx prisma/user-confirm.ts",
    "db:org:add-join-requests": "npx tsx prisma/org-add-join-requests.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@effect/platform": "^0.96.0",
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@marsidev/react-turnstile": "^1.4.2",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@types/pdfmake": "^0.3.1",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "arctic": "^3.7.0",
    "clsx": "^2.1.1",
    "d3-hierarchy": "^3.1.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "effect": "^3.21.0",
    "leo-profanity": "^1.9.0",
    "motion": "^12.23.26",
    "next": "16.0.7",
    "next-intl": "^4.5.8",
    "pdfmake": "^0.3.5",
    "pg": "^8.16.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-phone-input-2": "^2.15.1",
    "sonner": "^2.0.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.0.15",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "prisma": "^7.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.15"
  }
}
