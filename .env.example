# Environment variables declared in this file are automatically loaded.
# See the documentation for all the environment variables: https://pris.ly/d/prisma-schema

# PostgreSQL Database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Connection pool settings optimized for VPN stability
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/yourdb?schema=public&connect_timeout=10&pool_timeout=10&socket_timeout=10"

# Force Prisma to use binary engine for Node.js runtime
PRISMA_DISABLE_QUAINT_EXECUTORS=1

# Node.js (development or production)
NODE_ENV=development
PORT=3000

# Next.js
NEXT_PUBLIC_API_URL=https://resolutio.site

# Turnstile CAPTCHA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_CODE_SECRET=your_otp_code_secret

# SMS.RU
SMS_RU_API_ID=
# Set to "true" to simulate SMS without charge (backdoorCode returned). Do NOT use in production.
SMS_RU_TEST_MODE=
# Max cost per SMS in rubles. Messages exceeding this are blocked. Leave empty for no limit.
SMS_RU_MAX_COST_RUBLES=10
